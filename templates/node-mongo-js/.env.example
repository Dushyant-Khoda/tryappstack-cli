# Server
PORT=3000
DEBUG_MODE=true

# Logging
# month -> Src/Uploads/Logs/JAN-2026/info.log
# date  -> Src/Uploads/Logs/JAN-2026/01/info.log
LOG_STORAGE_STRATEGY=month

# Database
DB_URL=your_database_url

# JWT & Auth
JWT_SECRET=your_secret_key
JWT_EXPIRE=2d
COOKIE_EXPIRE=60

# AWS S3 (optional)
AWS_CLIENT_ID=your_aws_client_id
AWS_CLIENT_SECRET=your_aws_client_secret
AWS_REGION=your_aws_region
AWS_BUCKET_NAME=your_aws_bucket_name

# Frontend URL (for CORS etc.)
FRONTEND_URL=http://localhost:3000

# Email (SMTP)
SMTP_MAIL=your_smtp_email@example.com
SMTP_SERVICE=gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_PASS=your_smtp_password

# Storage: use S3 (true) or local/Cloudinary (false)
IS_S3=false

# Cloudinary (when IS_S3 is false)
CLOUD_NAME=your_cloudinary_cloud_name
CLOUD_API_KEY=your_cloudinary_api_key
CLOUD_API_SECRET=your_cloudinary_api_secret
