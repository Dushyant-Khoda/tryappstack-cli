{
    "env": {
        "node": true,
        "es2021": true,
        "jest": true
    },
    "extends": [
        "eslint:recommended",
        "prettier"
    ],
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module"
    },
    "rules": {
        "no-console": "warn",
        "no-unused-vars": [
            "warn",
            {
                "argsIgnorePattern": "^(next|req|res|_)"
            }
        ],
        "no-process-exit": "off"
    },
    "ignorePatterns": [
        "node_modules/",
        "coverage/",
        "Src/Uploads/"
    ]
}