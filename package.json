{
  "name": "tryappstack",
  "version": "1.0.3",
  "description": "CLI tool to bootstrap production-ready applications using modern boilerplates",
  "license": "MIT",
  "author": "Dushyant Khoda",
  "homepage": "https://tryappstack.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/Dushyant-Khoda/tryappstack-cli"
  },
  "bugs": {
    "url": "https://github.com/Dushyant-Khoda/tryappstack-cli/issues"
  },
  "main": "lib/commands/init.js",
  "bin": {
    "tryappstack": "./bin/cli.js",
    "tas": "./bin/cli.js"
  },
  "files": [
    "bin/",
    "lib/",
    "templates/"
  ],
  "scripts": {
    "test": "node bin/cli.js",
    "lint": "eslint bin lib --ignore-pattern 'templates/*'",
    "format": "prettier --write \"bin/**/*.js\" \"lib/**/*.js\"",
    "prepare": "husky || true"
  },
  "keywords": [
    "nodejs cli",
    "boilerplate generator",
    "project scaffolding",
    "node starter template",
    "backend boilerplate",
    "saas starter",
    "developer tools",
    "project generator",
    "node cli tool",
    "app boilerplate",
    "express boilerplate",
    "api starter template"
  ],
  "dependencies": {
    "chalk": "4.1.2",
    "commander": "^14.0.3",
    "figlet": "^1.8.0",
    "fs-extra": "^11.2.0",
    "inquirer": "^8.2.6",
    "ora": "5.4.1"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.5"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
